<Window x:Class="Huginn.App.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Huginn" Height="500" Width="800" Background="{DynamicResource MaterialDesignPaper}">
    <materialDesign:DrawerHost IsLeftDrawerOpen="{Binding ElementName=MenuToggleButton, Path=IsChecked}">
        <materialDesign:DrawerHost.LeftDrawerContent>
            <ListBox x:Name="MenuListBox" SelectionChanged="MenuListBox_SelectionChanged">
                <ListBoxItem Content="Главная" IsSelected="True"/><ListBoxItem Content="История"/><ListBoxItem Content="Настройки"/>
            </ListBox>
        </materialDesign:DrawerHost.LeftDrawerContent>
        <DockPanel>
            <materialDesign:ColorZone Mode="PrimaryMid" Padding="16" DockPanel.Dock="Top">
                <StackPanel Orientation="Horizontal"><ToggleButton x:Name="MenuToggleButton" Style="{StaticResource MaterialDesignHamburgerToggleButton}"/><TextBlock Text="Huginn Detector" VerticalAlignment="Center" Margin="16,0"/></StackPanel>
            </materialDesign:ColorZone>
            <Grid>
                <StackPanel x:Name="DashboardView" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="ShieldCheck" Width="80" Height="80" Foreground="{Binding StatusColor}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusText}" HorizontalAlignment="Center" FontSize="20"/>
                    <Button Content="Пауза" x:Name="PauseBtn" Click="TogglePause_Click" HorizontalAlignment="Center" Margin="20"/>
                </StackPanel>
                <DataGrid x:Name="HistoryView" Visibility="Collapsed" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns><DataGridTextColumn Header="Время" Binding="{Binding Timestamp}"/><DataGridTextColumn Header="Вероятность" Binding="{Binding Confidence, StringFormat=P1}"/></DataGrid.Columns>
                </DataGrid>
                <StackPanel x:Name="SettingsView" Visibility="Collapsed" Margin="20">
                    <TextBlock Text="Устройство"/><ComboBox x:Name="DeviceComboBox" Margin="0,10"/><TextBlock Text="Порог обнаружения"/><Slider x:Name="ThresholdSlider" Minimum="0.5" Maximum="0.95" Value="0.7" TickFrequency="0.05" IsSnapToTickEnabled="True"/><CheckBox x:Name="AutostartCheckBox" Content="Автозапуск"/><Button Content="Сохранить" Click="SaveSettings_Click" Margin="0,20"/>
                </StackPanel>
            </Grid>
        </DockPanel>
    </materialDesign:DrawerHost>
</Window>
